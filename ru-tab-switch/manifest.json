{
    "name": "RU Tab Switch",
    "description": "Add a keyboard shortcut for switching to the latest previously active tab",
    "version": "3.0",
    "manifest_version": 3,
    "permissions": [
        "tabs",
        "storage"
    ],
    "commands": {
        "tab-switch": {
            "suggested_key": {
                "default": "Alt+A"
            },
            "description": "Go to previously active tab"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}